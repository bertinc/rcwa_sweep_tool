@page "/"
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject RCWA_Sweep_Tool.Services.DesignParametersService DesignParameters
@inject NavigationManager Navigation

<div class="page-wrapper">
    <header>
        <h2>RCWA Sweep Tool</h2>
        <p class="header-subtitle">Efficiency and Modulation curves using Rigorous Coupled Wave Analysis</p>
    </header>

    <div class="main-container">
        <div class="design-values">
            <div class="nav-link">
                <a href="/raytrace" @onclick="@(() => Navigation.NavigateTo("/raytrace"))">Go to Ray Trace →</a>
            </div>
            
            <h3>Design Values</h3>
            
            <div class="input-field">
                <label>Spatial Frequency:</label>
                <div class="input-with-radio">
                    <input type="number" id="sf" @bind="SpatialFrequency" @bind:after="OnSpatialFrequencyChanged" step="10" min="100" max="4000" readonly="@(SelectedReadonlyField == "SF")" />
                    <span class="unit">l/mm</span>
                    <input type="radio" name="readonly-field" value="SF" @onchange="@((ChangeEventArgs e) => SelectedReadonlyField = e.Value?.ToString() ?? "")" checked="@(SelectedReadonlyField == "SF")" title="When selected, the spatial frequency will be readonly and auto-calculate." />
                </div>
            </div>
            
            <div class="input-field">
                <label>Center Wavelength:</label>
                <input type="number" id="cw" @bind="CenterWavelength" @bind:after="OnCenterWavelengthChanged" min="300" max="3000" step="10" />
                <span class="unit">nm</span>
            </div>
            
            <div class="input-field">
                <label>Start Wavelength:</label>
                <input type="number" id="sw" @bind="StartWavelength" min="300" max="3000" step="10" />
                <span class="unit">nm</span>
            </div>
            
            <div class="input-field">
                <label>End Wavelength:</label>
                <input type="number" id="ew" @bind="EndWavelength" min="300" max="3000" step="10" />
                <span class="unit">nm</span>
            </div>
            
            <div class="input-field">
                <label>Angle of Incidence:</label>
                <input type="number" id="aoi" @bind="AngleOfIncidence" @bind:after="OnAngleOfIncidenceChanged" step="0.01" />
                <span class="unit">deg</span>
            </div>
            
            <div class="input-field">
                <label>Angle of Diffraction:</label>
                <div class="input-with-radio">
                    <input type="number" id="aod" @bind="AngleOfDiffraction" @bind:after="OnAngleDiffractionChanged" step="0.01" readonly="@(SelectedReadonlyField == "AOD")" />
                    <span class="unit">deg</span>
                    <input type="radio" name="readonly-field" value="AOD" @onchange="@((ChangeEventArgs e) => SelectedReadonlyField = e.Value?.ToString() ?? "")" checked="@(SelectedReadonlyField == "AOD")" title="When selected, the angle of diffraction will be readonly and auto-calculate." />
                </div>
            </div>
            
            <div class="input-field">
                <label>Bragg Tilt:</label>
                <input type="number" id="bt" @bind="BraggTilt" step="0.01" readonly />
                <span class="unit">deg</span>
            </div>
            
            <div class="input-field">
                <label>Bulk Index:</label>
                <input type="number" id="bi" @bind="BulkIndex" @bind:after="OnBulkIndexChanged" min="1.00" max="3.00" step="0.01" />
            </div>
            
            <div class="input-field">
                <label>Glass Index:</label>
                <input type="number" id="gi" @bind="GlassIndex" min="1.000" max="2.000" step="0.001" />
            </div>
            
            <div class="input-field">
                <label>Delta n:</label>
                <input type="number" id="dn" @bind="DeltaN" @bind:after="OnDeltaNChanged" min="0.000" max="0.200" step="0.001" />
            </div>
            
            <div class="input-field">
                <label>Harmonic Order:</label>
                <input type="number" id="ho" @bind="HarmonicOrder" min="0" max="1" step="1" />
            </div>
            
            <div class="input-field">
                <label>Effective Thickness:</label>
                <input type="number" id="et" @bind="EffectiveThickness" min="3" max="25" step="1" />
                <span class="unit">µm</span>
            </div>
            
            <div class="input-field">
                <label>Thick Film Threshold:</label>
                <input type="number" id="tft" @bind="ThickFilmThreshold" step="0.01" readonly />
                <span class="unit">µm</span>
            </div>
            
            <div class="button-row">
                <button class="reset-defaults-btn-inline" @onclick="ResetToDefaults" title="Reset all values to defaults">Defaults</button>
                <button class="update-charts-btn" @onclick="RunBothSweeps">Update Charts</button>
            </div>
            
            <div class="button-row">
                <button class="save-defaults-btn" @onclick="SaveCurrentAsDefaults" title="Save current values as your defaults">Save</button>
            </div>
        </div>
        
        <div class="charts-container">
            <div class="chart-wrapper">
                <canvas @ref="chart1Canvas"></canvas>
                <div class="chart-controls">
                    <label class="chart-lock-label" title="Lock/Unlock zoom">
                        <input type="checkbox" @bind="IsChart1ZoomLocked" @bind:after="OnChart1ZoomLockChanged" />
                        🔒
                    </label>
                    <button class="chart-reset-btn" @onclick="() => ResetZoom(1)" title="Reset zoom">↺</button>
                </div>
            </div>
            <div class="chart-wrapper">
                <canvas @ref="chart2Canvas"></canvas>
                <div class="chart-controls">
                    <label class="chart-lock-label" title="Lock/Unlock zoom">
                        <input type="checkbox" @bind="IsChart2ZoomLocked" @bind:after="OnChart2ZoomLockChanged" />
                        🔒
                    </label>
                    <button class="chart-reset-btn" @onclick="() => ResetZoom(2)" title="Reset zoom">↺</button>
                </div>
            </div>
        </div>
    </div>

    <footer>
        <p>RCWA Sweep Tool v@(Constants.Version) - Free and Open Source</p>
        @if (!string.IsNullOrEmpty(StatusMessage))
        {
            <p class="@(IsError ? "status-error" : "status-success")">@StatusMessage</p>
        }
    </footer>
</div>

@code {
    private string StatusMessage { get; set; } = "";
    private bool IsError { get; set; } = false;
    private double[] LastReturnSPol { get; set; } = Array.Empty<double>();
    private double[] LastReturnPPol { get; set; } = Array.Empty<double>();
    private double[] LastWavelengths { get; set; } = Array.Empty<double>();
    private bool IsChart1ZoomLocked { get; set; } = true;
    private bool IsChart2ZoomLocked { get; set; } = true;

    private ElementReference chart1Canvas;
    private ElementReference chart2Canvas;
    private IJSObjectReference? module;

    // Convenience properties that map to the shared service
    private double SpatialFrequency
    {
        get => DesignParameters.SpatialFrequency;
        set => DesignParameters.SpatialFrequency = value;
    }

    private double CenterWavelength
    {
        get => DesignParameters.CenterWavelength;
        set => DesignParameters.CenterWavelength = value;
    }

    private double StartWavelength
    {
        get => DesignParameters.StartWavelength;
        set => DesignParameters.StartWavelength = value;
    }

    private double EndWavelength
    {
        get => DesignParameters.EndWavelength;
        set => DesignParameters.EndWavelength = value;
    }

    private double AngleOfIncidence
    {
        get => DesignParameters.AngleOfIncidence;
        set => DesignParameters.AngleOfIncidence = value;
    }

    private double AngleOfDiffraction
    {
        get => DesignParameters.AngleOfDiffraction;
        set => DesignParameters.AngleOfDiffraction = value;
    }

    private double BraggTilt
    {
        get => DesignParameters.BraggTilt;
        set => DesignParameters.BraggTilt = value;
    }

    private double BulkIndex
    {
        get => DesignParameters.BulkIndex;
        set => DesignParameters.BulkIndex = value;
    }

    private double GlassIndex
    {
        get => DesignParameters.GlassIndex;
        set => DesignParameters.GlassIndex = value;
    }

    private double DeltaN
    {
        get => DesignParameters.DeltaN;
        set => DesignParameters.DeltaN = value;
    }

    private double HarmonicOrder
    {
        get => DesignParameters.HarmonicOrder;
        set => DesignParameters.HarmonicOrder = value;
    }

    private double EffectiveThickness
    {
        get => DesignParameters.EffectiveThickness;
        set => DesignParameters.EffectiveThickness = value;
    }

    private double ThickFilmThreshold
    {
        get => DesignParameters.ThickFilmThreshold;
        set => DesignParameters.ThickFilmThreshold = value;
    }

    private string SelectedReadonlyField
    {
        get => DesignParameters.SelectedReadonlyField;
        set => DesignParameters.SelectedReadonlyField = value;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/Home.razor.js");
            
            // Initialize charts and properly await for them to be created
            await module.InvokeAsync<Task>("initializeCharts", chart1Canvas, chart2Canvas);
            
            // Run both sweeps on startup to populate the charts with default values
            await RunModulationSweep();
            await RunWavelengthSweep();
        }
    }

    private async Task RunBothSweeps()
    {
        // Clear any previous status messages
        StatusMessage = "";
        
        // Run modulation sweep first and get the optimal delta value
        double optimalDelta = await RunModulationSweep();
        
        // If a crossing was found, update DeltaN before running wavelength sweep
        if (optimalDelta >= 0)
        {
            DeltaN = Calc.Precision(optimalDelta, Constants.DELTA_SIG);
            // Update the modulation chart to show the red line at the new DeltaN position
            if (module is not null && LastReturnSPol.Length > 0)
            {
                double startDelta = 0.0;
                double stopDelta = 0.15;
                double stepDelta = (stopDelta - startDelta) / 200;
                int array_size = (int)((stopDelta - startDelta) / stepDelta) + 1;
                
                double[] deltaArray = new double[array_size];
                for (int i = 0; i < array_size; i++)
                {
                    deltaArray[i] = startDelta + (i * stepDelta);
                }
                
                await module.InvokeVoidAsync("updateModulationCurvesChart", deltaArray, LastReturnSPol, LastReturnPPol, DeltaN, optimalDelta);
            }
        }
        
        // Run wavelength sweep with the optimized DeltaN
        await RunWavelengthSweep();
    }

    private async Task RunWavelengthSweep()
    {
        try
        {
            if (module is null)
            {
                StatusMessage = "Module not initialized";
                IsError = true;
                return;
            }

            // Allocate arrays for results (adjust size as needed based on your DLL)
            int step = 1;
            int array_size = (int)((double)(EndWavelength - StartWavelength) / (double)step) + 1;
            double[] returnSPol = new double[array_size];
            double[] returnPPol = new double[array_size];
            // Calculate alphaG based on the angle of incidence and glass index
            double alphaG = Calc.Degrees(Math.Asin(Math.Sin(Calc.Radians(AngleOfIncidence)) / GlassIndex));

            double cw = CenterWavelength / 1000; // Convert nm to µm for DLL
            double sw = StartWavelength / 1000; // Convert nm to µm for DLL
            double ew = EndWavelength / 1000; // Convert nm to µm for DLL
            double st = (double)step / 1000; // Convert nm to µm for DLL

            RcwaDllInterop.wavelength_sweep(
                SpatialFrequency,
                EffectiveThickness,
                DeltaN,
                BulkIndex,
                GlassIndex,
                BraggTilt,
                (int)HarmonicOrder,
                cw,
                sw,
                ew,
                st,
                alphaG,
                returnSPol,
                returnPPol
            );

            // Store arrays for chart update
            LastReturnSPol = returnSPol;
            LastReturnPPol = returnPPol;

            // Generate wavelength array
            double[] wavelengths = new double[array_size];
            for (int i = 0; i < array_size; i++)
            {
                wavelengths[i] = StartWavelength + (i * step);
            }

            // Store wavelengths for chart updates
            LastWavelengths = wavelengths;

            // Update the chart with new data and pass current DeltaN for the vertical line
            await module.InvokeVoidAsync("updateDiffractionEfficiencyChart", wavelengths, returnSPol, returnPPol, CenterWavelength);
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error in wavelength sweep: {ex.Message}";
            IsError = true;
        }
    }

    private async Task<double> RunModulationSweep()
    {
        try
        {
            if (module is null)
            {
                StatusMessage = "Module not initialized";
                IsError = true;
                return -1;
            }

            // Display all input parameters before calling the DLL
            double startDelta = 0.0;
            double stopDelta = 0.15;
            double stepDelta = (stopDelta - startDelta) / 200;
            int array_size = (int)((stopDelta - startDelta) / stepDelta) + 1;
            
            double alphaG = Calc.Degrees(Math.Asin(Math.Sin(Calc.Radians(AngleOfIncidence)) / GlassIndex));
            double cw = CenterWavelength / 1000; // Convert nm to µm for DLL

            double[] returnSPol = new double[array_size];
            double[] returnPPol = new double[array_size];

            RcwaDllInterop.modulation_sweep(
                SpatialFrequency,
                EffectiveThickness,
                DeltaN,
                BulkIndex,
                GlassIndex,
                BraggTilt,
                (int)HarmonicOrder,
                cw,
                startDelta,
                stopDelta,
                stepDelta,
                alphaG,
                returnSPol,
                returnPPol
            );

            // Store modulation results for potential re-render
            LastReturnSPol = returnSPol;
            LastReturnPPol = returnPPol;

            // Generate delta array
            double[] deltaArray = new double[array_size];
            for (int i = 0; i < array_size; i++)
            {
                deltaArray[i] = startDelta + (i * stepDelta);
            }

            // Find the crossing with the highest/lowest value depending on harmonic order
            int crossingIndex = -1;
            if (HarmonicOrder == 0)
            {
                crossingIndex = FindLowestValueCrossing(returnSPol, returnPPol);
            }
            else
            {
                crossingIndex = FindHighestValueCrossing(returnSPol, returnPPol);
            }
            double optimalDelta = -1;
            if (crossingIndex >= 0)
            {
                optimalDelta = deltaArray[crossingIndex];
            }

            // Update modulation curves chart with new data and optimal delta for title
            await module.InvokeVoidAsync("updateModulationCurvesChart", deltaArray, returnSPol, returnPPol, DeltaN, optimalDelta);
            
            if (optimalDelta >= 0)
            {
                return optimalDelta;
            }
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error in modulation sweep: {ex.Message}";
            IsError = true;
        }
        
        return -1; // Return -1 if no crossing found or error occurred
    }

    private int FindHighestValueCrossing(double[] array1, double[] array2)
    {
        int highestCrossingIndex = -1;
        double highestValue = double.MinValue;
        
        // Find all crossings between the two arrays
        for (int i = 0; i < array1.Length - 1; i++)
        {
            // Check if there's a crossing between point i and i+1
            // A crossing occurs when the difference changes sign
            double diff1 = array1[i] - array2[i];
            double diff2 = array1[i + 1] - array2[i + 1];
            
            // If signs are different (diff1 * diff2 < 0), there's a crossing
            if (diff1 * diff2 < 0)
            {
                // Find the highest value at this crossing point
                double maxAtCrossing = Math.Max(array1[i], array2[i]);
                if (maxAtCrossing > highestValue)
                {
                    highestValue = maxAtCrossing;
                    highestCrossingIndex = i;
                }
            }
        }
        
        return highestCrossingIndex;
    }

    private int FindLowestValueCrossing(double[] array1, double[] array2)
    {
        int lowestCrossingIndex = -1;
        double lowestValue = double.MaxValue;
        
        // Find all crossings between the two arrays
        for (int i = 0; i < array1.Length - 1; i++)
        {
            // Check if there's a crossing between point i and i+1
            // A crossing occurs when the difference changes sign
            double diff1 = array1[i] - array2[i];
            double diff2 = array1[i + 1] - array2[i + 1];
            
            // If signs are different (diff1 * diff2 < 0), there's a crossing
            if (diff1 * diff2 < 0)
            {
                // Find the lowest value at this crossing point
                double maxAtCrossing = Math.Max(array1[i], array2[i]);
                if (maxAtCrossing < lowestValue)
                {
                    lowestValue = maxAtCrossing;
                    lowestCrossingIndex = i;
                }
            }
        }
        
        return lowestCrossingIndex;
    }

    private void OnDeltaNChanged()
    {
        // When user manually changes Delta N, automatically run wavelength sweep
        _ = RunWavelengthSweep();
    }

    private void UpdateThickFilmThreshold()
    {
        // Calculate thick film threshold
        ThickFilmThreshold = Calc.GetThickFilmThreshold(SpatialFrequency, BraggTilt, BulkIndex, CenterWavelength);
        
        // If Thick Film Threshold is greater than Effective Thickness, increase Effective Thickness
        if (ThickFilmThreshold > EffectiveThickness)
        {
            EffectiveThickness = Math.Ceiling(ThickFilmThreshold) + Constants.ET_SAFETY_MARGIN;
        }
    }

    private void OnSpatialFrequencyChanged()
    {
        if (SelectedReadonlyField == "SF")
        {
            // SF is readonly, recalculate it from CW, AOI, and AOD
            SpatialFrequency = Calc.GetSpatialFrequency(AngleOfIncidence, AngleOfDiffraction, CenterWavelength);
        }
        else if (SelectedReadonlyField == "AOD")
        {
            // AOD is readonly and SF changed, set symmetric angles
            double symAngle = Calc.GetSymetricAngles(SpatialFrequency, CenterWavelength);
            AngleOfIncidence = symAngle;
            AngleOfDiffraction = symAngle;
            // Update Bragg Tilt after angles change
            BraggTilt = Calc.GetBraggTilt(AngleOfIncidence, AngleOfDiffraction, BulkIndex);
        }
        // Update Thick Film Threshold after SF changes
        UpdateThickFilmThreshold();
        // Force UI update
        StateHasChanged();
    }

    private void OnCenterWavelengthChanged()
    {
        if (SelectedReadonlyField == "SF")
        {
            // SF is readonly, recalculate it from CW, AOI, and AOD
            SpatialFrequency = Calc.GetSpatialFrequency(AngleOfIncidence, AngleOfDiffraction, CenterWavelength);
        }
        else if (SelectedReadonlyField == "AOD")
        {
            // AOD is readonly and CW changed, set symmetric angles
            double symAngle = Calc.GetSymetricAngles(SpatialFrequency, CenterWavelength);
            AngleOfIncidence = symAngle;
            AngleOfDiffraction = symAngle;
            // Update Bragg Tilt after angles change
            BraggTilt = Calc.GetBraggTilt(AngleOfIncidence, AngleOfDiffraction, BulkIndex);
        }
        
        // Validate Start and End Wavelengths relative to Center Wavelength
        if (CenterWavelength > EndWavelength)
        {
            EndWavelength = CenterWavelength + 100;
        }
        if (CenterWavelength < StartWavelength)
        {
            StartWavelength = CenterWavelength - 100;
        }
        
        // Update Thick Film Threshold after CW changes
        UpdateThickFilmThreshold();
        
        // Force UI update
        StateHasChanged();
        
        // Update chart line position and title to reflect new center wavelength
        if (module is not null && LastWavelengths.Length > 0 && LastReturnSPol.Length > 0)
        {
            _ = module.InvokeVoidAsync("updateDiffractionEfficiencyChart", LastWavelengths, LastReturnSPol, LastReturnPPol, CenterWavelength);
        }
    }

    private void OnAngleOfIncidenceChanged()
    {
        if (SelectedReadonlyField == "SF")
        {
            // SF is readonly, recalculate it from CW, AOI, and AOD
            SpatialFrequency = Calc.GetSpatialFrequency(AngleOfIncidence, AngleOfDiffraction, CenterWavelength);
        }
        else if (SelectedReadonlyField == "AOD")
        {
            // AOD is readonly and AOI changed, update AOD from grating equation
            AngleOfDiffraction = Calc.GetAOD(SpatialFrequency, CenterWavelength, AngleOfIncidence);
        }
        // Update Bragg Tilt after AOI changes
        BraggTilt = Calc.GetBraggTilt(AngleOfIncidence, AngleOfDiffraction, BulkIndex);
        // Update Thick Film Threshold after BraggTilt changes
        UpdateThickFilmThreshold();
        // Force UI update
        StateHasChanged();
    }

    private void OnAngleDiffractionChanged()
    {
        if (SelectedReadonlyField == "SF")
        {
            // SF is readonly, recalculate it from CW, AOI, and AOD
            SpatialFrequency = Calc.GetSpatialFrequency(AngleOfIncidence, AngleOfDiffraction, CenterWavelength);
        }
        // Update Bragg Tilt after AOD changes
        BraggTilt = Calc.GetBraggTilt(AngleOfIncidence, AngleOfDiffraction, BulkIndex);
        // Update Thick Film Threshold after BraggTilt changes
        UpdateThickFilmThreshold();
        // Force UI update
        StateHasChanged();
    }

    private void OnBulkIndexChanged()
    {
        // Update Bragg Tilt when bulk index changes (affects refraction calculation)
        BraggTilt = Calc.GetBraggTilt(AngleOfIncidence, AngleOfDiffraction, BulkIndex);
        // Update Thick Film Threshold after bulk index changes
        UpdateThickFilmThreshold();
    }

    private async Task ResetZoom(int chartNumber)
    {
        if (module is not null)
        {
            await module.InvokeVoidAsync("resetZoomForChart", chartNumber);
        }
    }

    private async Task OnChart1ZoomLockChanged()
    {
        if (module is not null)
        {
            await module.InvokeVoidAsync("setZoomLock", 1, IsChart1ZoomLocked);
        }
    }

    private async Task OnChart2ZoomLockChanged()
    {
        if (module is not null)
        {
            await module.InvokeVoidAsync("setZoomLock", 2, IsChart2ZoomLocked);
        }
    }

    private void ResetToDefaults()
    {
        // Reset all parameters to their default values
        SpatialFrequency = 1200;
        CenterWavelength = 830;
        StartWavelength = 760;
        EndWavelength = 900;
        AngleOfIncidence = 29.87;
        AngleOfDiffraction = 29.87;
        BraggTilt = 90;
        BulkIndex = 1.33;
        GlassIndex = 1.444;
        DeltaN = 0.112;
        HarmonicOrder = 1;
        EffectiveThickness = 4;
        ThickFilmThreshold = 1.77;
        SelectedReadonlyField = "SF";
        DesignParameters.GlassThickness = 3.0;
        
        // Update calculated values
        UpdateThickFilmThreshold();
        
        // Update the charts with default values
        RunBothSweeps();
        
        StatusMessage = "All values reset to defaults and charts updated";
        IsError = false;
        StateHasChanged();
    }

    private void SaveCurrentAsDefaults()
    {
        // Save current values to persistent storage using MAUI Preferences
        DesignParameters.SaveAsDefaults();
        
        StatusMessage = "Current values saved as your defaults";
        IsError = false;
        StateHasChanged();
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        if (module is not null)
        {
            await module.DisposeAsync();
        }
    }
}
