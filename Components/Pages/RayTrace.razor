@page "/raytrace"
@inject RCWA_Sweep_Tool.Services.DesignParametersService DesignParameters
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="page-wrapper">
    <header>
        <h2>Ray Trace Analysis</h2>
        <p class="header-subtitle">Optical ray tracing for holographic gratings</p>
    </header>

    <div class="main-container">
        <div class="design-values">
            <div class="nav-link">
                <a href="/" @onclick="@(() => Navigation.NavigateTo("/"))">← Back to RCWA Sweep</a>
            </div>
            
            <h3>Design Parameters</h3>
            
            <div class="input-field">
                <label>Spatial Frequency:</label>
                <input type="number" @bind="DesignParameters.SpatialFrequency" step="10" min="100" max="4000" readonly />
                <span class="unit">l/mm</span>
            </div>
            
            <div class="input-field">
                <label>Center Wavelength:</label>
                <input type="number" @bind="DesignParameters.CenterWavelength" min="300" max="3000" step="10" readonly />
                <span class="unit">nm</span>
            </div>
            
            <div class="input-field">
                <label>Angle of Incidence:</label>
                <input type="number" @bind="DesignParameters.AngleOfIncidence" step="0.01" readonly />
                <span class="unit">deg</span>
            </div>
            
            <div class="input-field">
                <label>Angle of Diffraction:</label>
                <input type="number" @bind="DesignParameters.AngleOfDiffraction" step="0.01" readonly />
                <span class="unit">deg</span>
            </div>
            
            <div class="input-field">
                <label>Bulk Index:</label>
                <input type="number" @bind="DesignParameters.BulkIndex" min="1.00" max="3.00" step="0.01" readonly />
            </div>
            
            <div class="input-field">
                <label>Glass Index:</label>
                <input type="number" @bind="DesignParameters.GlassIndex" min="1.000" max="2.000" step="0.001" readonly />
            </div>
            
            <div class="input-field">
                <label>Effective Thickness:</label>
                <input type="number" @bind="DesignParameters.EffectiveThickness" min="1" max="100" step="0.1" readonly />
                <span class="unit">µm</span>
            </div>
            
            <div class="input-field">
                <label>Glass Thickness:</label>
                <input type="number" @bind="DesignParameters.GlassThickness" @bind:after="OnGlassThicknessChanged" min="0.5" max="10.0" step="0.1" />
                <span class="unit">mm</span>
            </div>
            
            <div class="zemax-command-section">
                <h4>Zemax Command</h4>
                <textarea class="zemax-command" readonly>@GetZemaxCommand()</textarea>
                <button class="copy-zemax-btn" @onclick="CopyZemaxToClipboard" title="Copy to clipboard">📋 Copy</button>
            </div>
        </div>
        
        <div class="content-area">
            <h3>Ray Trace Visualization</h3>
            <svg class="ray-trace-canvas" viewBox="0 0 1000 400" xmlns="http://www.w3.org/2000/svg">
                <!-- Layer backgrounds - Scaled: 25px = 1mm -->
                <!-- Air left: dynamically calculated to center the stack -->
                <rect x="0" y="0" width="@AirLeftWidth" height="400" fill="#e3f2fd" />
                <text x="@(AirLeftWidth/2)" y="350" text-anchor="middle" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" transform="rotate(-90, @(AirLeftWidth/2), 350)">Air (1.0)</text>
                
                <!-- Glass 1: dynamic thickness -->
                <rect x="@AirLeftWidth" y="0" width="@Glass1Width" height="400" fill="#bbdefb" />
                <text x="@(AirLeftWidth + Glass1Width/2)" y="350" text-anchor="middle" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" transform="rotate(-90, @(AirLeftWidth + Glass1Width/2), 350)">Glass (@DesignParameters.GlassIndex.ToString("F3"))</text>
                
                <!-- Film: EffectiveThickness in µm, converted to pixels (with minimum for visibility) -->
                <rect x="@Glass1Exit" y="0" width="@filmWidthPx" height="400" fill="#90caf9" />
                <text x="@(Glass1Exit + filmWidthPx/2)" y="350" text-anchor="middle" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" transform="rotate(-90, @(Glass1Exit + filmWidthPx/2), 350)">Film (@DesignParameters.BulkIndex.ToString("F2"))</text>
                
                <!-- Glass 2: dynamic thickness -->
                <rect x="@FilmExit" y="0" width="@Glass2Width" height="400" fill="#bbdefb" />
                <text x="@(FilmExit + Glass2Width/2)" y="350" text-anchor="middle" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" transform="rotate(-90, @(FilmExit + Glass2Width/2), 350)">Glass (@DesignParameters.GlassIndex.ToString("F3"))</text>
                
                <!-- Air right: equal to left air -->
                <rect x="@Glass2Exit" y="0" width="@AirRightWidth" height="400" fill="#e3f2fd" />
                <text x="@(Glass2Exit + AirRightWidth/2)" y="350" text-anchor="middle" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#333" transform="rotate(-90, @(Glass2Exit + AirRightWidth/2), 350)">Air (1.0)</text>
                
                <!-- Interface lines -->
                <line x1="@AirLeftWidth" y1="0" x2="@AirLeftWidth" y2="400" stroke="#333" stroke-width="2" />
                <line x1="@Glass1Exit" y1="0" x2="@Glass1Exit" y2="400" stroke="#333" stroke-width="2" />
                <line x1="@FilmExit" y1="0" x2="@FilmExit" y2="400" stroke="#333" stroke-width="2" />
                <line x1="@Glass2Exit" y1="0" x2="@Glass2Exit" y2="400" stroke="#333" stroke-width="2" />
                
                <!-- Ray path -->
                <polyline points="@GetRayPath()" fill="none" stroke="red" stroke-width="2" />
                
                <!-- Normal lines at interfaces -->
                <line x1="@AirLeftWidth" y1="@(incidentY - 50)" x2="@AirLeftWidth" y2="@(incidentY + 50)" stroke="gray" stroke-width="1" stroke-dasharray="3,3" />
                <line x1="@Glass1Exit" y1="@(glass1ExitY - 50)" x2="@Glass1Exit" y2="@(glass1ExitY + 50)" stroke="gray" stroke-width="1" stroke-dasharray="3,3" />
                <line x1="@FilmExit" y1="@(filmExitY - 50)" x2="@FilmExit" y2="@(filmExitY + 50)" stroke="gray" stroke-width="1" stroke-dasharray="3,3" />
                <line x1="@Glass2Exit" y1="@(glass2ExitY - 50)" x2="@Glass2Exit" y2="@(glass2ExitY + 50)" stroke="gray" stroke-width="1" stroke-dasharray="3,3" />
            </svg>
            
            <div class="ray-info">
                <h4>Ray Trace Information</h4>
                <p><strong>Incident Angle (Air):</strong> @DesignParameters.AngleOfIncidence.ToString("F2")°</p>
                <p><strong>Refracted Angle (Glass):</strong> @glass1Angle.ToString("F2")°</p>
                <p><strong>Diffraction Angle (Film - 1st Order):</strong> @filmAngle.ToString("F2")°</p>
                <p><strong>Exit Angle (Air):</strong> @exitAngle.ToString("F2")°</p>
                <p style="margin-top: 10px; font-style: italic; color: #666;">
                    The ray refracts at glass interfaces and diffracts at the holographic grating in the film.
                </p>
            </div>
        </div>
    </div>

    <footer>
        <p>RCWA Sweep Tool v@(Constants.Version) - Free and Open Source | <a href="/donation" class="donation-link">❤️ Support Development</a></p>
    </footer>
</div>

@code {
    private double incidentY = 200;
    private double glass1ExitY = 200;
    private double filmExitY = 200;
    private double glass2ExitY = 200;
    private double glass1Angle = 0;
    private double filmAngle = 0;
    private double exitAngle = 0;
    private double filmWidthPx = 40; // Film width in pixels (calculated from effective thickness)

    // Layer positions - calculated to center the material stack
    private const double TotalSvgWidth = 1000; // Increased from 800
    private double Glass1Width => DesignParameters.GlassThickness * 25; // Glass thickness in mm × 25px/mm
    private double Glass2Width => DesignParameters.GlassThickness * 25; // Glass thickness in mm × 25px/mm
    
    private double AirWidth => (TotalSvgWidth - Glass1Width - filmWidthPx - Glass2Width) / 2;
    private double AirLeftWidth => AirWidth;
    private double Glass1Exit => AirLeftWidth + Glass1Width;
    private double FilmExit => Glass1Exit + filmWidthPx;
    private double Glass2Exit => FilmExit + Glass2Width;
    private double AirRightWidth => AirWidth;

    protected override void OnInitialized()
    {
        // Parameters are automatically loaded from the shared service
        CalculateFilmWidth();
        CalculateRayPath();
    }

    protected override void OnParametersSet()
    {
        CalculateFilmWidth();
        CalculateRayPath();
    }

    private void OnGlassThicknessChanged()
    {
        // Recalculate ray path when glass thickness changes
        CalculateRayPath();
    }

    private void OnAngleChanged()
    {
        // Recalculate ray path when angles or indices change
        CalculateRayPath();
    }

    private void CalculateFilmWidth()
    {
        // Scale: 25 pixels = 1mm = 1000 µm
        // filmWidthPx = EffectiveThickness (µm) × (25px / 1000µm)
        double calculatedWidth = DesignParameters.EffectiveThickness * 0.025;
        
        // Use minimum of 40px for visibility (even if film is thinner in reality)
        filmWidthPx = Math.Max(40, calculatedWidth);
    }

    private void CalculateRayPath()
    {
        // Starting point in air
        incidentY = 200;
        
        // Air to Glass 1 (refraction) - using centralized Calc method
        glass1Angle = Calc.GetRefractionAngle(DesignParameters.AngleOfIncidence, 1.0, DesignParameters.GlassIndex);
        double glass1AngleRad = Calc.Radians(glass1Angle);
        
        // Calculate y offset in glass layer
        double glass1TravelY = Glass1Width * Math.Tan(glass1AngleRad);
        glass1ExitY = incidentY + glass1TravelY;
        
        // Glass 1 to Film entrance (refraction)
        double filmEntranceAngle = Calc.GetRefractionAngle(glass1Angle, DesignParameters.GlassIndex, DesignParameters.BulkIndex);
        
        // **Calculate what angle in FILM corresponds to the desired exit angle in AIR**
        // The AngleOfDiffraction is specified in air, so work backwards:
        // Air → Glass → Film
        
        // Air to Glass angle for diffracted beam
        double glassOutAngle = Calc.GetRefractionAngle(DesignParameters.AngleOfDiffraction, 1.0, DesignParameters.GlassIndex);
        
        // Glass to Film angle for diffracted beam  
        double filmDiffractionAngle = Calc.GetRefractionAngle(glassOutAngle, DesignParameters.GlassIndex, DesignParameters.BulkIndex);
        double filmDiffractionAngleRad = Calc.Radians(filmDiffractionAngle);
        
        filmAngle = filmDiffractionAngle;
        
        // Calculate y offset in film layer (filmWidthPx pixels wide)
        // NEGATE to get correct direction: positive angle = up, negative angle = down
        double filmTravelY = -filmWidthPx * Math.Tan(filmDiffractionAngleRad);
        filmExitY = glass1ExitY + filmTravelY;
        
        // Film to Glass 2 (refraction)
        double glass2Angle = Calc.GetRefractionAngle(filmDiffractionAngle, DesignParameters.BulkIndex, DesignParameters.GlassIndex);
        double glass2AngleRad = Calc.Radians(glass2Angle);
        
        // Calculate y offset in glass 2 layer
        double glass2TravelY = -Glass2Width * Math.Tan(glass2AngleRad);
        glass2ExitY = filmExitY + glass2TravelY;
        
        // Glass 2 to Air (refraction)
        exitAngle = Calc.GetRefractionAngle(glass2Angle, DesignParameters.GlassIndex, 1.0);
    }

    private string GetRayPath()
    {
        // Incident ray in air
        double startX = 0;
        double startY = incidentY - AirLeftWidth * Math.Tan(Calc.Radians(DesignParameters.AngleOfIncidence));
        
        // Exit ray continues through right air layer
        double exitY = glass2ExitY - AirRightWidth * Math.Tan(Calc.Radians(exitAngle));
        
        // Build the polyline path through all layers
        return $"{startX},{startY} " +
               $"{AirLeftWidth},{incidentY} " +
               $"{Glass1Exit},{glass1ExitY} " +
               $"{FilmExit},{filmExitY} " +
               $"{Glass2Exit},{glass2ExitY} " +
               $"{TotalSvgWidth},{exitY}";
    }

    private string GetZemaxCommand()
    {
        // Generate a complete Zemax OpticStudio script with the full optical system
        // Format: Air - Glass - Film (Holographic Grating) - Glass - Air
        
        double filmThicknessMm = DesignParameters.EffectiveThickness / 1000.0; // Convert µm to mm
        
        return $"! Holographic Grating Optical System\n" +
               $"! Generated from RCWA Sweep Tool v{Constants.Version}\n" +
               $"! Date: {DateTime.Now:yyyy-MM-dd HH:mm:ss}\n" +
               $"!\n" +
               $"! Design Parameters:\n" +
               $"! Spatial Frequency: {DesignParameters.SpatialFrequency:F1} l/mm\n" +
               $"! Center Wavelength: {DesignParameters.CenterWavelength:F1} nm\n" +
               $"! Incident Angle: {DesignParameters.AngleOfIncidence:F2}°\n" +
               $"! Diffraction Angle: {DesignParameters.AngleOfDiffraction:F2}°\n" +
               $"! Glass Index: {DesignParameters.GlassIndex:F3}\n" +
               $"! Glass Thickness: {DesignParameters.GlassThickness:F2} mm\n" +
               $"! Bulk Index: {DesignParameters.BulkIndex:F2}\n" +
               $"! Film Thickness: {DesignParameters.EffectiveThickness:F2} µm\n" +
               $"!\n" +
               $"! System Setup\n" +
               $"NEWLENS\n" +
               $"UNITS MM\n" +
               $"!\n" +
               $"! Define Wavelength\n" +
               $"WAVE {DesignParameters.CenterWavelength / 1000:F4}\n" +
               $"!\n" +
               $"! Surface 0: Object at infinity\n" +
               $"SURP 0 TYPE STANDARD\n" +
               $"SURP 0 THIC Infinity\n" +
               $"!\n" +
               $"! Surface 1: Front of Glass 1\n" +
               $"INSR 1\n" +
               $"SURP 1 TYPE STANDARD\n" +
               $"SURP 1 CURV 0\n" +
               $"SURP 1 THIC {DesignParameters.GlassThickness:F4}\n" +
               $"SURP 1 GLAS MISC {DesignParameters.GlassIndex:F4} 0 0 0 0 0 0 0 0 0\n" +
               $"SURP 1 DIAM 10\n" +
               $"!\n" +
               $"! Surface 2: Back of Glass 1 / Front of Film\n" +
               $"INSR 2\n" +
               $"SURP 2 TYPE STANDARD\n" +
               $"SURP 2 CURV 0\n" +
               $"SURP 2 THIC {filmThicknessMm:F6}\n" +
               $"SURP 2 GLAS MISC {DesignParameters.BulkIndex:F4} 0 0 0 0 0 0 0 0 0\n" +
               $"SURP 2 DIAM 10\n" +
               $"!\n" +
               $"! Surface 3: Back of Film (Holographic Grating) / Front of Glass 2\n" +
               $"INSR 3\n" +
               $"SURP 3 TYPE HOLO\n" +
               $"SURP 3 CURV 0\n" +
               $"SURP 3 THIC {DesignParameters.GlassThickness:F4}\n" +
               $"SURP 3 GLAS MISC {DesignParameters.GlassIndex:F4} 0 0 0 0 0 0 0 0 0\n" +
               $"SURP 3 DIAM 10\n" +
               $"! Holographic parameters\n" +
               $"SURP 3 PAR 1 {1000.0 / DesignParameters.SpatialFrequency:F6}\n" +
               $"SURP 3 PAR 2 0\n" +
               $"SURP 3 PAR 3 1\n" +
               $"SURP 3 PAR 4 0\n" +
               $"SURP 3 PAR 5 0\n" +
               $"SURP 3 PAR 6 0\n" +
               $"!\n" +
               $"! Surface 4: Back of Glass 2\n" +
               $"INSR 4\n" +
               $"SURP 4 TYPE STANDARD\n" +
               $"SURP 4 CURV 0\n" +
               $"SURP 4 THIC 50\n" +
               $"SURP 4 DIAM 10\n" +
               $"!\n" +
               $"! Surface 5: Image plane\n" +
               $"INSR 5\n" +
               $"SURP 5 TYPE STANDARD\n" +
               $"SURP 5 CURV 0\n" +
               $"SURP 5 DIAM 10\n" +
               $"!\n" +
               $"! Set incident angle (field angle)\n" +
               $"FTYP ANGL 0 0 0\n" +
               $"FWAV 1 1\n" +
               $"FWGN 1 1\n" +
               $"FLDY 1 {DesignParameters.AngleOfIncidence:F4}\n" +
               $"FLDY 2 0\n" +
               $"!\n" +
               $"! Update\n" +
               $"UPDATE\n" +
               $"!\n" +
               $"! Expected diffraction angle: {DesignParameters.AngleOfDiffraction:F2}°\n";
    }

    private async Task CopyZemaxToClipboard()
    {
        string command = GetZemaxCommand();
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", command);
    }
}
